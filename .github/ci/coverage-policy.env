# Aggregate statement baseline is measured from unit plus native PTY, tmux,
# and loopback SSH executable journeys. Only CI/test qualification packages
# that are not linked into the shipped executable are excluded.
COVERAGE_FLOOR=80.0
COVERAGE_TOLERANCE=0.5
EXCLUDE_PREFIXES=github.com/taiwong148960/intent-sh/internal/artifactqual,github.com/taiwong148960/intent-sh/internal/citest,github.com/taiwong148960/intent-sh/internal/coveragequal
